version="2026.04.23"

show_help() {
  cat > /dev/stdout << END
todo - Command Line Todo List Manager

OPTIONAL FLAGS:
  [no flags]                       Show current TODO list
  -e                               open TODO list in \$EDITOR
  -a message                       Add a message to TODO list
  -d [number] or [string]          Delete message(s) that match parameter
  -u                               Restore most recent archived message
  -j / --json                      Show list output in JSON
  -x                               Use archive context for list/edit/add/delete
  -v                               Show current version number
  -h                               Show this help
END
}

TODO="${TODO:-${HOME}/todo.txt}"
JSON_OUTPUT=0

if [ "${1:-}" = "--json" ]; then
  JSON_OUTPUT=1
  shift
fi

archive_lines() {
  archive_file=$1
  while IFS= read -r line; do
    [ -n "$line" ] || continue
    printf "%s - %s\\n" "$(date +"%Y-%m-%d %H:%M:%S")" "$line" >> "$archive_file"
  done
}

sorted_lines() {
  input_file=$1
  awk '
    {
      pri = 99999
      if ($0 ~ /^P[1-9][[:space:]]+/) {
        tmp = $0
        sub(/^P/, "", tmp)
        sub(/[[:space:]].*$/, "", tmp)
        pri = tmp + 0
      }
      printf "%05d|%09d|%s\n", pri, NR, $0
    }
  ' "$input_file" | sort -t'|' -k1,1n -k2,2n | cut -d'|' -f3-
}

json_from_stream() {
  awk '
    BEGIN {
      first = 1
      print "["
    }
    {
      s = $0
      gsub(/\\/, "\\\\", s)
      gsub(/"/, "\\\"", s)
      gsub(/\t/, "\\t", s)
      gsub(/\r/, "\\r", s)
      if (!first) {
        printf ",\n"
      }
      printf "  {\"id\": %d, \"text\": \"%s\"}", NR, s
      first = 0
    }
    END {
      if (!first) {
        printf "\n"
      }
      print "]"
    }
  '
}

show_file() {
  input_file=$1
  if [ ! -f "$input_file" ]; then
    if [ "$JSON_OUTPUT" -eq 1 ]; then
      printf "[]\n"
    fi
    return 0
  fi

  if [ "$JSON_OUTPUT" -eq 1 ]; then
    sorted_lines "$input_file" | json_from_stream
  else
    sorted_lines "$input_file" | awk '{ print NR, "-", $0 }'
  fi
}

set_action() {
  next_action=$1
  next_arg=$2
  if [ "$ACTION_SET" -eq 1 ]; then
    exit 1
  fi
  ACTION=$next_action
  ACTION_ARG=$next_arg
  ACTION_SET=1
}

delete_from_file() {
  target_file=$1
  delete_arg=$2
  should_archive=$3

  if [ ! -f "$target_file" ]; then
    return 1
  fi

  if printf "%s" "$delete_arg" | grep -Eq '^[+-][0-9]+$'; then
    return 1
  fi

  if printf "%s" "$delete_arg" | grep -Eq '^[0-9]+$'; then
    if [ "$delete_arg" -eq 0 ]; then
      return 1
    fi
    match=$(sed -n "${delete_arg}p" "$target_file" 2> /dev/null)
    if sed -i.bak -e "${delete_arg}d" "$target_file" 2> /dev/null; then
      rm -f "$target_file".bak
    else
      return 1
    fi
    if [ "$should_archive" -eq 1 ] && [ -n "$match" ]; then
      printf "%s\\n" "$match" | archive_lines "$TODOARCHIVEFILE"
    fi
    return 0
  fi

  targetpath=$(dirname "$target_file")
  tmp_target=$(mktemp "$targetpath/.todo.tmp.XXXXXX") || return 1
  tmp_match=$(mktemp "$targetpath/.todo.match.tmp.XXXXXX") || { rm -f "$tmp_target"; return 1; }

  if awk -v needle="$delete_arg" '
      index($0, needle) { print > match_file; found=1; next }
      { print > out_file }
      END { if (found) exit 0; else exit 2 }
    ' out_file="$tmp_target" match_file="$tmp_match" "$target_file"; then
    if mv "$tmp_target" "$target_file"; then
      if [ "$should_archive" -eq 1 ]; then
        archive_lines "$TODOARCHIVEFILE" < "$tmp_match"
      fi
    else
      rm -f "$tmp_target" "$tmp_match"
      return 1
    fi
  else
    rc=$?
    rm -f "$tmp_target"
    if [ "$rc" -ne 2 ]; then
      rm -f "$tmp_match"
      return 1
    fi
  fi

  rm -f "$tmp_match"
  return 0
}

# If we are in a tmux session, name the file with the session name
# If not in tmux, use the full $TODO env var for path/file
if printf "%s" "$TERM" | grep -Fq screen && test "$TMUX" ; then
  sessname=$(tmux display -p '#S' 2> /dev/null)
  # if session name is numeric, it's not descriptive enough
  # to warrant renaming the todo file. Ignore it and use default
  if [ -z "$sessname" ] || printf "%s" "$sessname" | grep -Eq '^[+-]?[0-9]+$'; then
    TODOFILE=$TODO
    TODOARCHIVEFILE=${TODO%.*}.archive.txt
  else
    todopath=$(dirname "$TODO")
    TODOFILE=$todopath/$sessname".txt"
    TODOARCHIVEFILE=$todopath/$sessname".archive.txt"
  fi
else
  TODOFILE=$TODO
  TODOARCHIVEFILE=${TODO%.*}.archive.txt
fi

ACTION="list"
ACTION_ARG=""
ACTION_SET=0
ARCHIVE_CONTEXT=0

while getopts "hvea:d:xuj" arg; do
  case "$arg" in
    h) # help
      set_action "help" ""
      ;;
    v) # version
      set_action "version" ""
      ;;
    j) # json output mode
      JSON_OUTPUT=1
      ;;
    e) # edit file
      set_action "edit" ""
      ;;
    a) # add item
      set_action "add" "$OPTARG"
      ;;
    x) # view archive
      ARCHIVE_CONTEXT=1
      ;;
    u) # undo most recent archived entry back into todo list
      set_action "undo" ""
      ;;
    d) # delete item(s) matching pattern
      set_action "delete" "$OPTARG"
      ;;
    ?) # unknown option
      exit 1
      ;;
  esac
done

shift "$((OPTIND - 1))"
if [ "$ACTION" = "add" ] && [ "$#" -gt 0 ]; then
  if [ -n "$ACTION_ARG" ]; then
    ACTION_ARG="$ACTION_ARG $*"
  else
    ACTION_ARG="$*"
  fi
  set --
fi
if [ "$ACTION" = "delete" ] && [ "$#" -gt 0 ]; then
  if [ -n "$ACTION_ARG" ]; then
    ACTION_ARG="$ACTION_ARG $*"
  else
    ACTION_ARG="$*"
  fi
  set --
fi
if [ "$#" -gt 0 ]; then
  exit 1
fi

if [ "$ARCHIVE_CONTEXT" -eq 1 ]; then
  ACTIVEFILE=$TODOARCHIVEFILE
else
  ACTIVEFILE=$TODOFILE
fi

case "$ACTION" in
  help)
    show_help
    exit 0
    ;;
  version)
    printf "%s\\n" "$version"
    exit 0
    ;;
  edit)
    printf "Opening %s in %s\\n" "$ACTIVEFILE" "${EDITOR:-nano}"
    if ${EDITOR:-nano} "${ACTIVEFILE}"; then
      exit 0
    fi
    exit 1
    ;;
  add)
    if [ -z "$ACTION_ARG" ]; then
      exit 1
    fi
    if printf "%s\\n" "$ACTION_ARG" >> "$ACTIVEFILE"; then
      exit 0
    fi
    exit 1
    ;;
  delete)
    if [ "$ARCHIVE_CONTEXT" -eq 1 ]; then
      delete_from_file "$ACTIVEFILE" "$ACTION_ARG" 0 && exit 0
      exit 1
    fi
    delete_from_file "$ACTIVEFILE" "$ACTION_ARG" 1 && exit 0
    exit 1
    ;;
  undo)
    if [ ! -s "$TODOARCHIVEFILE" ]; then
      exit 1
    fi
    last_entry=$(tail -n 1 "$TODOARCHIVEFILE" 2> /dev/null) || exit 1
    restored=${last_entry#* - }
    if ! printf "%s\\n" "$restored" >> "$TODOFILE"; then
      exit 1
    fi
    todopath=$(dirname "$TODOARCHIVEFILE")
    tmp_archive=$(mktemp "$todopath/.todo.archive.tmp.XXXXXX") || exit 1
    if sed '$d' "$TODOARCHIVEFILE" > "$tmp_archive" && mv "$tmp_archive" "$TODOARCHIVEFILE"; then
      exit 0
    fi
    rm -f "$tmp_archive"
    exit 1
    ;;
  list)
    show_file "$ACTIVEFILE"
    exit 0
    ;;
esac

exit 1
